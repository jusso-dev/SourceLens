# --- Database ---
DATABASE_URL="postgresql://sourcelens:sourcelens@localhost:5432/sourcelens?schema=public"

# --- Redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- better-auth ---
BETTER_AUTH_SECRET="dev-only-secret-change-me-please-32chars"
BETTER_AUTH_URL="http://localhost:3000"
# When "true" newly-registered users must click the email link before signing in.
# Default false so the demo stays one-click. The same value must be exposed as
# NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION for client-side routing decisions.
BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION="false"
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION="false"

# --- Storage ---
STORAGE_BACKEND="local"       # local | s3 | azure (azure reserved for a later adapter)
STORAGE_DIR="./storage"
S3_ENDPOINT=""                # e.g. http://localhost:9000 for MinIO/R2-compatible APIs
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"   # true for MinIO and many S3-compatible APIs

# Comma-separated emails that may access internal operator tools like Bull Board.
INTERNAL_ADMIN_EMAILS=""

# --- Email (invitations, verification, password reset) ---
# Provider: console | resend | smtp | mock
EMAIL_PROVIDER="console"
EMAIL_FROM=""               # required for resend/smtp, e.g. "SourceLens <no-reply@your.tld>"
RESEND_API_KEY=""
SMTP_URL=""                 # e.g. smtps://user:pass@smtp.example.com:465
SMTP_FROM=""                # optional override of EMAIL_FROM for smtp

# --- LLM providers (all optional; mocks used when unset) ---
# Primary chat: Claude Agent SDK
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Optional reranker for hybrid retrieval before RAG answers.
# none | cohere | voyage | ollama
RERANKER="none"
COHERE_API_KEY=""
COHERE_RERANK_MODEL="rerank-v3.5"
VOYAGE_API_KEY=""
VOYAGE_RERANK_MODEL="rerank-2.5"

# Fallback chat + embeddings: Ollama (local)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_CHAT_MODEL="gemma3:4b"
OLLAMA_EMBED_MODEL="nomic-embed-text"
OLLAMA_RERANK_MODEL="mxbai-rerank-large"

# Embedding dimension must match Prisma vector column. nomic-embed-text=768.
EMBEDDING_DIM=768

# Prompt-injection guard on retrieved chunks: warn (default) | strip | block
RAG_INJECTION_MODE=warn

# --- Limits ---
MAX_UPLOAD_BYTES=26214400  # 25 MB

# --- Rate limiting (per user, token-bucket via Redis) ---
RATE_LIMIT_UPLOAD_BURST=5
RATE_LIMIT_UPLOAD_PER_HOUR=30
RATE_LIMIT_SEARCH_BURST=60
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_ASK_BURST=20
RATE_LIMIT_ASK_PER_MINUTE=20
RATE_LIMIT_RETRY_BURST=10
RATE_LIMIT_RETRY_PER_MINUTE=10

# --- Anonymous rate limiting (per client IP) ---
RATE_LIMIT_ANON_SIGNIN_BURST=5
RATE_LIMIT_ANON_SIGNIN_PER_HOUR=30
RATE_LIMIT_ANON_SIGNUP_BURST=3
RATE_LIMIT_ANON_SIGNUP_PER_HOUR=10
RATE_LIMIT_ANON_INVITE_BURST=30
RATE_LIMIT_ANON_INVITE_PER_HOUR=120
RATE_LIMIT_ANON_RESET_BURST=3
RATE_LIMIT_ANON_RESET_PER_HOUR=10
RATE_LIMIT_ANON_VERIFY_BURST=3
RATE_LIMIT_ANON_VERIFY_PER_HOUR=6

# Honour X-Forwarded-For / Forwarded headers when set to "1" or "true".
# Leave unset in local dev to avoid client-spoofed IP. Enable behind a
# trusted reverse proxy / load balancer (Cloudflare, NGINX, Vercel).
TRUST_PROXY=""
