# --- Database ---
DATABASE_URL="postgresql://sourcelens:sourcelens@localhost:5432/sourcelens?schema=public"

# --- Redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- better-auth ---
BETTER_AUTH_SECRET="dev-only-secret-change-me-please-32chars"
BETTER_AUTH_URL="http://localhost:3000"

# --- Storage ---
STORAGE_DIR="./storage"

# --- Email (invitations, verification, password reset) ---
# Provider: console | resend | smtp | mock
EMAIL_PROVIDER="console"
EMAIL_FROM=""               # required for resend/smtp, e.g. "SourceLens <no-reply@your.tld>"
RESEND_API_KEY=""
SMTP_URL=""                 # e.g. smtps://user:pass@smtp.example.com:465
SMTP_FROM=""                # optional override of EMAIL_FROM for smtp

# --- LLM providers (all optional; mocks used when unset) ---
# Primary chat: Claude Agent SDK
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Fallback chat + embeddings: Ollama (local)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_CHAT_MODEL="gemma3:4b"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# Embedding dimension must match Prisma vector column. nomic-embed-text=768.
EMBEDDING_DIM=768

# Prompt-injection guard on retrieved chunks: warn (default) | strip | block
RAG_INJECTION_MODE=warn

# --- Limits ---
MAX_UPLOAD_BYTES=26214400  # 25 MB

# --- Rate limiting (per user, token-bucket via Redis) ---
RATE_LIMIT_UPLOAD_BURST=5
RATE_LIMIT_UPLOAD_PER_HOUR=30
RATE_LIMIT_SEARCH_BURST=60
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_ASK_BURST=20
RATE_LIMIT_ASK_PER_MINUTE=20
RATE_LIMIT_RETRY_BURST=10
RATE_LIMIT_RETRY_PER_MINUTE=10
